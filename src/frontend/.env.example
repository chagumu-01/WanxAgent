# Frontend Environment Variables

# API Base URL Configuration
# IMPORTANT: For local development, leave this EMPTY (vite.config.ts proxy handles API routing)
# Only set this when deploying frontend separately or in production
VITE_API_BASE_URL=

# Application Title
VITE_APP_TITLE=WanxAgent

# Development Server Port
VITE_DEV_PORT=8090

# Example for production (uncomment and set when deploying)
# VITE_API_BASE_URL=https://your-api-domain.com