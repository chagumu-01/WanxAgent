# Server Configuration
SERVER_HOST=127.0.0.1
SERVER_PORT=7860

# MySQL Database Configuration
MYSQL_ENDPOINT=mysql+pymysql://root:password@localhost:3306/wanxagent
MYSQL_ASYNC_ENDPOINT=mysql+aiomysql://root:password@localhost:3306/wanxagent

# Redis Configuration
REDIS_ENDPOINT=redis://localhost:6379

# Multi-Model Configuration (LLM)
CONVERSATION_MODEL_API_KEY=your_conversation_model_api_key
CONVERSATION_MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
CONVERSATION_MODEL_NAME=qwen3.5-plus

TOOL_CALL_MODEL_API_KEY=your_tool_call_model_api_key
TOOL_CALL_MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
TOOL_CALL_MODEL_NAME=qwen3.5-plus

REASONING_MODEL_API_KEY=your_reasoning_model_api_key
REASONING_MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
REASONING_MODEL_NAME=qwen3.5-plus

TEXT2IMAGE_API_KEY=your_text2image_api_key
TEXT2IMAGE_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/text2image/image-synthesis
TEXT2IMAGE_MODEL_NAME=wanx2.0-t2i-turbo

QWEN_VL_API_KEY=your_qwen_vl_api_key
QWEN_VL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_VL_MODEL_NAME=qwen-vl-plus

# Embedding Model Configuration
EMBEDDING_API_KEY=your_embedding_api_key
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL_NAME=text-embedding-v3

# Rerank Model Configuration
RERANK_API_KEY=your_rerank_api_key
RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
RERANK_MODEL_NAME=qwen-vl-rerank

# External Tools Configuration
WEATHER_API_KEY=your_weather_api_key
TAVILY_API_KEY=your_tavily_api_key
GOOGLE_API_KEY=your_google_api_key
DELIVERY_API_KEY=your_delivery_api_key
BOCHA_API_KEY=your_bocha_api_key

# RAG Configuration
RAG_ENABLE_SUMMARY=False
RAG_ENABLE_ELASTICSEARCH=False
RAG_TOP_K=5
RAG_MIN_SCORE=0.2
RAG_CHUNK_SIZE=500
RAG_OVERLAP_SIZE=100

# Elasticsearch Configuration
ELASTICSEARCH_HOSTS=http://127.0.0.1:9200

# Vector Database Configuration
VECTOR_DB_HOST=127.0.0.1
VECTOR_DB_PORT=19530
VECTOR_DB_MODE=chroma

# Storage Configuration (minio or oss)
STORAGE_MODE=minio

# OSS Configuration
OSS_ACCESS_KEY_ID=your_oss_access_key_id
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_BUCKET_NAME=wanxagent
OSS_BASE_URL=https://wanxagent.oss-cn-beijing.aliyuncs.com

# MinIO Configuration
MINIO_ACCESS_KEY_ID=minioadmin
MINIO_ACCESS_KEY_SECRET=minioadmin
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_BUCKET_NAME=wanxagent
MINIO_BASE_URL=http://127.0.0.1:9000/wanxagent

# Default Configuration
MCP_LOGO_URL=https://wanxagent.oss-cn-beijing.aliyuncs.com/icons/mcp/mcp.png
TOOL_LOGO_URL=https://wanxagent.oss-cn-beijing.aliyuncs.com/icons/tools/default.png
AGENT_LOGO_URL=https://wanxagent.oss-cn-beijing.aliyuncs.com/icons/tools/bot.png
MARS_DAILY_URL=https://news.aibase.com/zh/news
MEMORY_COLLECTION_NAME=memory

# WeChat Configuration (Optional)
WECHAT_TOKEN=your_wechat_token
WECHAT_APP_ID=your_wechat_app_id
WECHAT_SECRET=your_wechat_secret

# Langfuse Configuration (Optional)
LANGFUSE_TRACE_NAME=wanxagent
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_USER_ID=your_langfuse_user_id